# ================================================================
# UstaBor.uz — .env.example
# Bu faylni nusxalab .env nomiga saqlang
# DIQQAT: .env faylini git ga qo'shmang!
# ================================================================

# ── Server ───────────────────────────────────────────────────────
NODE_ENV=development
PORT=5000
FRONTEND_URL=http://localhost:3000

# ── PostgreSQL ────────────────────────────────────────────────────
DB_HOST=localhost
DB_PORT=5432
DB_NAME=ustabor
DB_USER=postgres
DB_PASSWORD=sizning_parolingiz

# ── Redis ─────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379

# ── JWT (xavfsiz kalit yaratish: openssl rand -hex 64) ────────────
JWT_SECRET=bu_yerga_uzun_va_tasodifiy_kalit_yozing

# ── Click to'lov tizimi ───────────────────────────────────────────
# https://my.click.uz → Developer kabinet
CLICK_SERVICE_ID=12345
CLICK_MERCHANT_ID=12345
CLICK_SECRET_KEY=click_secret_kalitingiz
CLICK_USER_ID=12345

# ── SMS (Eskiz.uz) ────────────────────────────────────────────────
# https://eskiz.uz → Ro'yxatdan o'ting
ESKIZ_EMAIL=sizning@email.com
ESKIZ_PASSWORD=eskiz_parolingiz
ESKIZ_TOKEN=eskiz_jwt_tokeningiz

# ── Fayl saqlash (ixtiyoriy) ──────────────────────────────────────
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=ap-south-1
AWS_BUCKET_NAME=ustabor-fayllar
