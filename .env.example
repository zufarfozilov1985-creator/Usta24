# MUHIT (development | production)
NODE_ENV=development

# SERVER
PORT=5000
FRONTEND_URL=https://yechim24.uz
ALLOWED_ORIGINS=https://yechim24.uz,https://www.yechim24.uz

# ─── POSTGRESQL ────────────────────────────
DB_HOST=localhost
DB_PORT=5432
DB_NAME=usta24
DB_USER=postgres
DB_PASSWORD=KUCHLI_PAROL_BU_YERGA

# ─── JWT (kamida 32 belgi!) ─────────────────
# Yaratish uchun: node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
JWT_SECRET=bu_yerga_kamida_32_belgili_maxfiy_kalit_yozing_1234567890abcdef

# ─── CLICK TO'LOV ───────────────────────────
CLICK_SERVICE_ID=12345
CLICK_MERCHANT_ID=12345
